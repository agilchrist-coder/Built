# Base44 API configuration
# Copy this file to .env.local and fill in your values.

# The base URL for the Base44 API (no trailing slash)
NEXT_PUBLIC_BASE44_URL=https://api.base44.app

# Your Base44 secret API key — keep this server-side only (no NEXT_PUBLIC_ prefix)
BASE44_API_KEY=your_base44_api_key_here
